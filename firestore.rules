rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isHouseholdMember() {
      return request.auth != null &&
             request.auth.uid in ['xEuUHmWcIWMARbDRRm92wnqdJNm2', 'f6sjxhcoQfNyJHuJb15wkVWvOl92'];
    }

    match /chores/{choreId} {
      allow read, write: if isHouseholdMember();
    }

    match /completions/{completionId} {
      allow read, write: if isHouseholdMember();
    }

    match /categories/{categoryId} {
      allow read, write: if isHouseholdMember();
    }

    match /users/{userId} {
      allow read: if isHouseholdMember();
      allow write: if isHouseholdMember() && request.auth.uid == userId;
    }
  }
}
